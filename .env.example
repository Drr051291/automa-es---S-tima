# =============================================================================
# Odoo
# =============================================================================
ODOO_URL=https://seu-odoo.odoo.com
ODOO_DB=nome_do_banco
ODOO_USER=seu@email.com
ODOO_API_KEY=sua_chave_api_odoo

# Pipeline (Sales Team) — deixe 0 para usar o padrão do Odoo
# Para descobrir o ID: acesse Odoo > CRM > Configurações > Equipes de vendas
ODOO_TEAM_ID=0

# Estágio inicial do lead — deixe 0 para usar o padrão
# Para descobrir o ID: acesse Odoo > CRM > Configurações > Estágios
ODOO_STAGE_ID=0

# =============================================================================
# Google Sheets
# =============================================================================
# Caminho para o arquivo JSON da conta de serviço do Google Cloud
GOOGLE_CREDENTIALS_FILE=google-credentials.json

# ID da planilha (extraído da URL do Sheets)
SPREADSHEET_ID=12UT2WhaIWsjZW-ojJ1Asy6bH3zaTsDLcRdwiKN3D3_I

# Nome da aba (deixe vazio para usar a primeira aba)
SHEET_NAME=

# =============================================================================
# Estado
# =============================================================================
# Arquivo que armazena os IDs dos leads já importados
PROCESSED_IDS_FILE=processed_ids.json
